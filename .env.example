# Copy this file to .env and edit the values if you want overrides, then run:
# docker compose up -d

# Optional: password override for the single user.
# Leave blank to create a hashed password in the browser on first launch.
# APP_PASSWORD=

# Optional: port the dashboard is served on (default 3007).
# PORT=3007

# Optional: secret used to sign the session cookie.
# Leave unset to have one generated and persisted automatically on first run.
# SESSION_SECRET=

# Optional: canonical browser origin for reverse proxies that rewrite Host.
# Example: PUBLIC_ORIGIN=https://forge.example.com
# PUBLIC_ORIGIN=

# Optional: trust X-Forwarded-* headers from your reverse proxy.
# Enable only when The Forge is behind a proxy you control.
# TRUST_PROXY=1
